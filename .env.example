# API Authentication Token (required for production)
# Leave empty to use default dev token (NOT RECOMMENDED for production)
PROXY_API_TOKEN=your_secret_token_here

# Proxy Pool Refresh Interval in seconds (default: 600)
CHECK_INTERVAL=600

# Self Proxy Configuration (optional)
# Used when proxy_type="self" in /api/proxy/forward endpoint
# Format: http://user:pass@host:port or socks5://user:pass@host:port
# If empty, requests will be forwarded directly without proxy
# SELF_PROXY_HOST=http://user:pass@proxy.example.com:8080
# SELF_PROXY_HOST=socks5://user:pass@proxy.example.com:1080

# Server Configuration (optional)
HOST=0.0.0.0
PORT=8000

# Logging (optional)
LOG_LEVEL=INFO